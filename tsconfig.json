{
    "compilerOptions": {
        "target": "es2023",
        "module": "esnext",
        "lib": [
            "ES2023",
            "DOM",
            "DOM.Iterable"
        ],
        "skipLibCheck": true,
        "jsx": "react-jsx",
        "jsxImportSource": "toad.jsx/lib",
        "types": ["@webgpu/types"],
        // "typeRoots": [
        //     "./node_modules/@webgpu/types",
        //     "./node_modules/@types",
        // ],
        /* Bundler mode */
        "moduleResolution": "bundler",
        "allowImportingTsExtensions": true,
        "verbatimModuleSyntax": true,
        "moduleDetection": "force",
        "noEmit": true,
        /* Linting */
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "erasableSyntaxOnly": false,
        "noFallthroughCasesInSwitch": true
    },
    "include": [
        "src"
    ]
}